# ============================================================
# InvestAI — Backend Environment Variables
# ============================================================
# Copy this file to `.env` and fill in your own values.
# cp .env.example .env

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── PostgreSQL Database ──────────────────────────────────────
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
# The database and all tables are created automatically on startup.
POSTGRES_URI=postgresql://postgres:YOUR_PASSWORD@localhost:5432/investai

# ── JWT Authentication ───────────────────────────────────────
# Generate a strong random string (e.g. openssl rand -hex 48)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=200d

# ── Email (SMTP) ─────────────────────────────────────────────
# Used for OTP verification and password reset emails.
# With Gmail: enable 2FA and create an App Password at
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=InvestAI <no-reply@investai.com>

# ── LLM Provider ─────────────────────────────────────────────
# Set LLM_PROVIDER to one of: gemini | openai | claude
LLM_PROVIDER=gemini

# Google Gemini — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_gemini_api_key

# OpenAI (optional) — https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key

# Anthropic Claude (optional) — https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Alpha Vantage (Stock Data) ────────────────────────────────
# Free key at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key

# ── LiveKit Voice Agent ───────────────────────────────────────
# Sign up free at https://livekit.io/ → create a project → Settings → API Keys
# Leave empty to run in offline Demo Simulation Mode.
LIVEKIT_URL=wss://your-project-name.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
